###############################################################################
# NexusOS Media Stack — Environment Configuration
# Copy this file to .env and edit the values below
#   cp .env.template .env
###############################################################################

# ── User / Group / Timezone ──────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/New_York

# ── Storage Paths ────────────────────────────────────────────────────────────
# Where service configs live (persistent state)
CONFIG_PATH=/opt/nexus-os/media-stack/config

# Where finished media is stored (movies, tv, music, books, etc.)
MEDIA_PATH=/mnt/media

# Where download clients write to (transient)
DOWNLOAD_PATH=/mnt/downloads

# ── VPN (Gluetun) ───────────────────────────────────────────────────────────
VPN_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=changeme
WIREGUARD_ADDRESSES=10.66.212.1/32
VPN_COUNTRIES=Switzerland
VPN_INPUT_PORTS=6881

# ── Service Ports (override defaults) ───────────────────────────────────────
QBIT_PORT=8080
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
LIDARR_PORT=8686
READARR_PORT=8787
BAZARR_PORT=6767
JELLYFIN_PORT=8096
OVERSEERR_PORT=5055
TAUTULLI_PORT=8181
ORGANIZR_PORT=8500
CALIBRE_WEB_PORT=8084
AUDIOBOOKSHELF_PORT=13378
AUTOSCAN_PORT=3030
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── Plex ─────────────────────────────────────────────────────────────────────
# Get a claim token from https://www.plex.tv/claim/
PLEX_CLAIM=

# ── API Keys (populate after first run of each service) ─────────────────────
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
READARR_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexus
