# Caddy reverse proxy for Vaultwarden
# Uses self-signed cert for LAN access (no domain needed)
# If you have a real domain, replace the IP with your domain and remove tls internal

{
  # Disable ACME for LAN-only (self-signed)
  # Remove this block if using a real domain
  local_certs
}

https://192.168.12.20 {
  tls internal

  reverse_proxy /notifications/hub vaultwarden:3012
  reverse_proxy vaultwarden:80
}
