# Authentik SSO — CT-107
# Copy to .env and fill in values

# PostgreSQL (CT-106)
AUTHENTIK_PG_HOST=192.168.12.106
AUTHENTIK_PG_USER=authentik
AUTHENTIK_PG_NAME=authentik
AUTHENTIK_PG_PASSWORD=        # Set a strong password — must match pg user

# Valkey/Redis (CT-105)
AUTHENTIK_REDIS_HOST=192.168.12.105

# Secret key — generate with: openssl rand -base64 36
AUTHENTIK_SECRET_KEY=         # REQUIRED — worker will crash without this
