# === GPU SPOOFING ===
# Create fake GPU info
cat > "$HOME/.config/ghost-mode/fake-gpu" << EOF
Intel Corporation UHD Graphics 620 (rev 07)
EOF

# === FONT SPOOFING (Minimal font set) ===
echo "🔤 Setting up minimal font set for anonymity..."
mkdir -p "$HOME/.config/ghost-mode/fonts"

# Create minimal fonts.conf
cat > "$HOME/.config/ghost-mode/fonts.conf" << EOF
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <!-- Minimal font configuration for anonymity -->
  <selectfont>
    <rejectfont>
      <glob>*</glob>
    </rejectfont>
    <acceptfont>
      <pattern>
        <patelt name="family">
          <string>DejaVu Sans</string>
          <string>Liberation Sans</string>
          <string>Arial</string>
          <string>Times New Roman</string>
          <string>Courier New</string>
        </patelt>
      </pattern>
    </acceptfont>
  </selectfont>
</fontconfig>
EOF

# === CREATE HARDWARE SPOOFING WRAPPER ===
cat > "$HOME/.local/bin/ghost-exec" << 'EOF'
#!/bin/bash

# 🥷 Ghost Execution Wrapper - Runs programs with spoofed hardware info
# Usage: ghost-exec [program] [args...]

export GHOST_MODE=1

# Spoof /proc/cpuinfo
if [ -f "$HOME/.config/ghost-mode/fake-cpuinfo" ]; then
    export LD_PRELOAD="$HOME/.config/ghost-mode/libfakecpu.so:$LD_PRELOAD"
fi

# Spoof memory info
if [ -f "$HOME/.config/ghost-mode/fake-meminfo" ]; then
    export LD_PRELOAD="$HOME/.config/ghost-mode/libfakemem.so:$LD_PRELOAD"
fi

# Use minimal font configuration
export FONTCONFIG_FILE="$HOME/.config/ghost-mode/fonts.conf"

# Randomize some environment variables
export LC_TIME="C"
export TZ="UTC"

# Randomize home directory for this session (temporary)
export FAKE_HOME="/tmp/ghost-home-$$"
mkdir -p "$FAKE_HOME"

# Launch program with spoofed environment
echo "🥷 Launching $1 with spoofed hardware fingerprint..."
exec "$@"
EOF

chmod +x "$HOME/.local/bin/ghost-exec"

# === SYSTEM HARDWARE INFO SPOOFING ===
echo "🛠️  Creating system-level hardware spoofing..."

# Create DMI spoofing info
sudo mkdir -p /tmp/ghost-dmi
cat > /tmp/ghost-dmi-info << EOF
# Fake DMI information for complete hardware anonymity
dmidecode-fake-bios-vendor: American Megatrends Inc.
dmidecode-fake-bios-version: 1.10.0
dmidecode-fake-system-manufacturer: ASUS
dmidecode-fake-system-product-name: VivoBook_ASUSLaptop X570ZD_K570ZD
dmidecode-fake-system-version: 1.0
dmidecode-fake-baseboard-manufacturer: ASUSTeK COMPUTER INC.
dmidecode-fake-baseboard-product-name: X570ZD
EOF

echo "✅ Hardware fingerprinting spoofing configured!"
echo ""
echo "🎯 Usage:"
echo "   ghost-exec firefox          # Launch Firefox with spoofed hardware"
echo "   ghost-exec chromium         # Launch Chromium with spoofed hardware"
echo "   ghost-exec [any-program]    # Run any program with spoofed fingerprints"
echo ""
echo "🔍 Spoofed components:"
echo "   ✓ CPU: Intel i5-8250U (4 cores, 1.6GHz)"
echo "   ✓ RAM: 8GB DDR4"
echo "   ✓ GPU: Intel UHD Graphics 620"  
echo "   ✓ Screen: $RANDOM_RES (randomized)"
echo "   ✓ Fonts: Minimal set (5 fonts only)"
echo "   ✓ System: ASUS VivoBook X570ZD"
