#!/bin/bash

# 🥷 Hardware Fingerprint Spoofer - Make your system unrecognizable
# Spoofs CPU, GPU, memory, screen resolution, and other hardware identifiers

echo "🥷 Activating Hardware Fingerprint Spoofing..."

# Create spoofing configuration directory
mkdir -p "$HOME/.config/ghost-mode"

# === SCREEN RESOLUTION SPOOFING ===
# List of common resolutions to randomize
RESOLUTIONS=(
    "1920x1080"
    "1366x768" 
    "1440x900"
    "1600x900"
    "1280x1024"
    "1024x768"
)

# Pick random resolution
RANDOM_RES=${RESOLUTIONS[$RANDOM % ${#RESOLUTIONS[@]}]}
WIDTH=$(echo $RANDOM_RES | cut -d'x' -f1)
HEIGHT=$(echo $RANDOM_RES | cut -d'x' -f2)

echo "🖥️  Spoofing screen resolution to: $RANDOM_RES"

# Create xrandr script for resolution spoofing
cat > "$HOME/.config/ghost-mode/spoof-display.sh" << EOF
#!/bin/bash
# Temporary display spoofing
xrandr --output \$(xrandr | grep " connected" | head -1 | cut -d' ' -f1) --mode $RANDOM_RES 2>/dev/null || true
EOF

chmod +x "$HOME/.config/ghost-mode/spoof-display.sh"

# === CPU SPOOFING ===
# Create fake cpuinfo that applications might read
cat > "$HOME/.config/ghost-mode/fake-cpuinfo" << EOF
processor	: 0
vendor_id	: GenuineIntel
cpu family	: 6
model		: 158
model name	: Intel(R) Core(TM) i5-8250U CPU @ 1.60GHz
stepping	: 10
microcode	: 0xf0
cpu MHz		: 1800.000
cache size	: 6144 KB
physical id	: 0
siblings	: 4
core id		: 0
cpu cores	: 4
apicid		: 0
initial apicid	: 0
fpu		: yes
fpu_exception	: yes
cpuid level	: 22
wp		: yes
flags		: fpu vme de pse tsc msr pae mce cx8 apic sep mtrr pge mca cmov pat pse36 clflush dts acpi mmx fxsr sse sse2 ss ht tm pbe syscall nx pdpe1gb rdtscp lm constant_tsc art arch_perfmon pebs bts rep_good nopl xtopology nonstop_tsc cpuid aperfmperf pni pclmulqdq dtes64 monitor ds_cpl vmx est tm2 ssse3 sdbg fma cx16 xtpr pdcm pcid sse4_1 sse4_2 x2apic movbe popcnt tsc_deadline_timer aes xsave avx f16c rdrand lahf_lm abm 3dnowprefetch cpuid_fault epb invpcid_single pti ssbd ibrs ibpb stibp tpr_shadow vnmi flexpriority ept vpid ept_ad fsgsbase tsc_adjust bmi1 avx2 smep bmi2 erms invpcid mpx rdseed adx smap clflushopt intel_pt xsaveopt xsavec xgetbv1 xsaves dtherm ida arat pln pts hwp hwp_notify hwp_act_window hwp_epp md_clear flush_l1d
bugs		: cpu_meltdown spectre_v1 spectre_v2 spec_store_bypass l1tf mds swapgs taa itlb_multihit srbds mmio_stale_data retbleed
bogomips	: 3600.00
clflush size	: 64
cache_alignment	: 64
address sizes	: 39 bits physical, 48 bits virtual
power management:
EOF

# === MEMORY SPOOFING ===
# Create fake meminfo
cat > "$HOME/.config/ghost-mode/fake-meminfo" << EOF
MemTotal:        8063168 kB
MemFree:         2341234 kB
MemAvailable:    5847382 kB
Buffers:          456789 kB
Cached:          3049359 kB
SwapCached:            0 kB
Active:          4293847 kB
Inactive:        1211486 kB
Active(anon):    2000000 kB
Inactive(anon):   100000 kB
Active(file):    2293847 kB
Inactive(file):  1111486 kB
Unevictable:           0 kB
Mlocked:               0 kB
SwapTotal:       8191996 kB
SwapFree:        8191996 kB
Dirty:                24 kB
Writeback:             0 kB
AnonPages:       1999756 kB
Mapped:           456123 kB
Shmem:            100468 kB
KReclaimable:     567890 kB
Slab:             890123 kB
SReclaimable:     567890 kB
SUnreclaim:       322233 kB
