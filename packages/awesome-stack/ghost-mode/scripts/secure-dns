#!/bin/bash

# 🥷 Ultimate DNS Leak Prevention System
# Prevents ALL DNS leaks, IPv6 leaks, and implements encrypted DNS

echo "🛡️ Activating Ultimate DNS Leak Prevention..."

# Create secure DNS configuration
mkdir -p "$HOME/.config/ghost-mode/dns"

# === DISABLE IPv6 COMPLETELY ===
echo "🚫 Disabling IPv6 to prevent leaks..."
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1

# Make IPv6 disable permanent
echo "net.ipv6.conf.all.disable_ipv6 = 1" | sudo tee -a /etc/sysctl.conf
echo "net.ipv6.conf.default.disable_ipv6 = 1" | sudo tee -a /etc/sysctl.conf
echo "net.ipv6.conf.lo.disable_ipv6 = 1" | sudo tee -a /etc/sysctl.conf

# === SECURE DNS SERVERS (Randomized) ===
SECURE_DNS_SERVERS=(
    "1.1.1.1 1.0.0.1"           # Cloudflare
    "8.8.8.8 8.8.4.4"           # Google (less private but reliable)
    "9.9.9.9 149.112.112.112"   # Quad9
    "208.67.222.222 208.67.220.220" # OpenDNS
    "45.90.28.0 45.90.30.0"     # NextDNS
)

# Pick random DNS servers
SELECTED_DNS=${SECURE_DNS_SERVERS[$RANDOM % ${#SECURE_DNS_SERVERS[@]}]}
PRIMARY_DNS=$(echo $SELECTED_DNS | cut -d' ' -f1)
SECONDARY_DNS=$(echo $SELECTED_DNS | cut -d' ' -f2)

echo "🔒 Using randomized DNS servers: $PRIMARY_DNS, $SECONDARY_DNS"

# === CONFIGURE SYSTEMD-RESOLVED FOR SECURE DNS ===
sudo mkdir -p /etc/systemd/resolved.conf.d/
cat > /tmp/ghost-dns.conf << EOF
[Resolve]
DNS=$PRIMARY_DNS $SECONDARY_DNS
FallbackDNS=
Domains=
DNSSEC=yes
DNSOverTLS=yes
Cache=no
DNSStubListener=no
ReadEtcHosts=no
ResolveUnicastSingleLabel=no
EOF

sudo cp /tmp/ghost-dns.conf /etc/systemd/resolved.conf.d/ghost-dns.conf

# === BLOCK DNS LEAKS AT FIREWALL LEVEL ===
echo "🔥 Creating firewall rules to block DNS leaks..."

# Create iptables rules to block all DNS except through VPN
sudo iptables -I OUTPUT -p udp --dport 53 -j REJECT 2>/dev/null || true
sudo iptables -I OUTPUT -p tcp --dport 53 -j REJECT 2>/dev/null || true

# Allow DNS only on VPN interface (if WireGuard is active)
if ip link show wg0 >/dev/null 2>&1; then
    sudo iptables -I OUTPUT -o wg0 -p udp --dport 53 -j ACCEPT 2>/dev/null || true
    sudo iptables -I OUTPUT -o wg0 -p tcp --dport 53 -j ACCEPT 2>/dev/null || true
    echo "✅ DNS allowed only on WireGuard interface"
fi

# === DNS LEAK TEST FUNCTION ===
cat > "$HOME/.local/bin/dns-leak-test" << 'EOF'
#!/bin/bash

echo "🔍 Testing for DNS leaks..."

echo "=== Current DNS Configuration ==="
resolvectl status 2>/dev/null || systemd-resolve --status 2>/dev/null || cat /etc/resolv.conf

echo ""
echo "=== Testing DNS Servers ==="
for server in 1.1.1.1 8.8.8.8 9.9.9.9; do
    echo -n "Testing $server: "
    if timeout 3 nslookup google.com $server >/dev/null 2>&1; then
        echo "✅ REACHABLE (POTENTIAL LEAK!)"
    else
        echo "❌ BLOCKED (GOOD)"
    fi
done

echo ""
echo "=== IPv6 Status ==="
if ip -6 addr show | grep -q "inet6.*global"; then
    echo "⚠️  IPv6 addresses found (POTENTIAL LEAK)"
    ip -6 addr show | grep "inet6.*global"
else
    echo "✅ No IPv6 global addresses (GOOD)"
fi

echo ""
echo "=== WebRTC Leak Test ==="
echo "🌐 Open Firefox and visit: https://browserleaks.com/webrtc"
echo "   Should show NO local/public IP addresses"

echo ""
echo "=== DNS Leak Test URLs ==="
echo "🌐 Test at: https://dnsleaktest.com"
echo "🌐 Test at: https://ipleak.net"
echo "   Should show your VPN's DNS servers only"
EOF

chmod +x "$HOME/.local/bin/dns-leak-test"

# === MAC ADDRESS RANDOMIZATION ===
echo "🎭 Setting up MAC address randomization..."

cat > /tmp/mac-randomize.conf << 'EOF'
[device]
wifi.scan-rand-mac-address=yes

[connection]
wifi.cloned-mac-address=random
ethernet.cloned-mac-address=random
connection.stable-id=${CONNECTION}/${BOOT}
EOF

sudo cp /tmp/mac-randomize.conf /etc/NetworkManager/conf.d/99-random-mac.conf

# === TRAFFIC PATTERN OBFUSCATION ===
cat > "$HOME/.local/bin/traffic-obfuscation" << 'EOF'
#!/bin/bash

# 🌪️ Network Traffic Pattern Obfuscation
# Generates random background traffic to mask real activity

echo "🌪️ Starting traffic pattern obfuscation..."

# Function to generate random traffic
generate_noise_traffic() {
    while true; do
        # Random delay between requests (1-60 seconds)
        sleep $((RANDOM % 60 + 1))
        
        # Random domains to query
        NOISE_DOMAINS=(
            "example.com"
            "httpbin.org" 
            "jsonplaceholder.typicode.com"
            "httpstat.us"
            "postman-echo.com"
        )
        
        DOMAIN=${NOISE_DOMAINS[$RANDOM % ${#NOISE_DOMAINS[@]}]}
        
        # Make random request (curl with timeout)
        timeout 5 curl -s "https://$DOMAIN" >/dev/null 2>&1 &
        
        # Limit concurrent connections
        job_count=$(jobs -r | wc -l)
        if [ $job_count -gt 3 ]; then
            wait
        fi
    done
}

# Run traffic obfuscation in background
if [ "$1" = "start" ]; then
    generate_noise_traffic &
    echo $! > "$HOME/.config/ghost-mode/traffic-obfuscation.pid"
    echo "✅ Traffic obfuscation started (PID: $!)"
elif [ "$1" = "stop" ]; then
    if [ -f "$HOME/.config/ghost-mode/traffic-obfuscation.pid" ]; then
        kill $(cat "$HOME/.config/ghost-mode/traffic-obfuscation.pid") 2>/dev/null
        rm "$HOME/.config/ghost-mode/traffic-obfuscation.pid"
        echo "✅ Traffic obfuscation stopped"
    fi
elif [ "$1" = "status" ]; then
    if [ -f "$HOME/.config/ghost-mode/traffic-obfuscation.pid" ]; then
        if kill -0 $(cat "$HOME/.config/ghost-mode/traffic-obfuscation.pid") 2>/dev/null; then
            echo "✅ Traffic obfuscation is running"
        else
            echo "❌ Traffic obfuscation is not running"
            rm "$HOME/.config/ghost-mode/traffic-obfuscation.pid"
        fi
    else
        echo "❌ Traffic obfuscation is not running"
    fi
else
    echo "Usage: traffic-obfuscation [start|stop|status]"
fi
EOF

chmod +x "$HOME/.local/bin/traffic-obfuscation"

# Restart systemd-resolved to apply changes
sudo systemctl restart systemd-resolved

echo "✅ DNS leak prevention configured!"
echo ""
echo "🎯 Available commands:"
echo "   dns-leak-test           # Test for DNS leaks"
echo "   traffic-obfuscation     # Manage traffic obfuscation"
echo ""
echo "🔒 Protections active:"
echo "   ✓ IPv6 completely disabled"
echo "   ✓ DNS forced through VPN only"
echo "   ✓ DNS-over-TLS enabled"
echo "   ✓ MAC address randomization"
echo "   ✓ DNS servers randomized: $PRIMARY_DNS, $SECONDARY_DNS"
echo ""
echo "⚠️  Restart NetworkManager to apply MAC randomization:"
echo "   sudo systemctl restart NetworkManager"
