{
  "name": "hyperion",
  "private": true,
  "version": "0.1.0",
  "description": "🌟 Hyperion - Linux Power Utilities that Illuminate Your Desktop",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "app:dev": "npm run tauri:dev",
    "app:build": "npm run tauri:build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "type-check": "tsc --noEmit",
    "utilities:build": "cargo build --manifest-path utilities/Cargo.toml",
    "utilities:install": "./scripts/install-utilities.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-window-state": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@headlessui/react": "^2.1.2",
    "@heroicons/react": "^2.1.5",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.28",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.5.4",
    "react-beautiful-dnd": "^13.1.1",
    "react-window": "^1.8.8",
    "react-hotkeys-hook": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.2.2",
    "vite": "^5.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/Hyperion.git"
  },
  "keywords": [
    "hyperion",
    "linux-utilities",
    "power-tools",
    "desktop-productivity",
    "tauri",
    "react",
    "rust",
    "linux-desktop",
    "power-users",
    "native-gui"
  ],
  "author": "Hyperion Team",
  "license": "MIT",
  "workspaces": [
    "utilities/*"
  ]
}