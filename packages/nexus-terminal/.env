# NexusTerminal Environment Configuration
# Generated for: RTX 4080 Laptop GPU (12GB VRAM), Ollama 0.18.0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
# OLLAMA_MODELS is auto-discovered at startup:
#   1. ~/.ollama/models (default)
#   2. Any mounted drive at /media/$USER/*/models or /mnt/*/models
# Set this only to override auto-discovery:
# OLLAMA_MODELS=/path/to/your/models

# Default model for completions/code
OLLAMA_MODEL=deepseek-coder-v2:16b

# ── Model Router ──────────────────────────────────────────────────────────────────────
# Like Warp, NexusTerminal uses a different model for each task type.
# The router auto-detects installed models and falls back through priority chains.
# Override any role by setting the env var below (only used if the model is installed).

# Tool use / orchestration — must follow JSON function-calling reliably
# Auto-priority: hermes3:8b → llama3.1:8b → nous-hermes2:10.7b
AGENT_MODEL=llama3.1:8b
# AGENT_TOOL_MODEL=hermes3:8b   # uncomment to override tool-use model

# Code fix / generation — best at writing correct code
# Auto-priority: codestral:22b → deepseek-coder-v2:16b → qwen2.5-coder:7b → yi-coder:9b
# AGENT_CODE_MODEL=codestral:22b   # uncomment to override code-fix model

# Code analysis / review — best at reading and understanding code
# Auto-priority: deepseek-coder-v2:16b → granite-code:latest → granite-code:8b
# AGENT_ANALYSIS_MODEL=deepseek-coder-v2:16b

# Deep reasoning — triggered by ** prefix e.g. "** redesign the agent loop"
# Auto-priority: llama3.3:70b → mixtral:8x7b → phi4:latest
AGENT_DEEP_MODEL=llama3.3:70b

# Fast chat — quick replies, command explanation
# Auto-priority: llama3.2:3b → phi3.5:3.8b → tinydolphin:1.1b
# AGENT_FAST_MODEL=llama3.2:3b

# Embedding (RAG)
# EMBED_MODEL=nomic-embed-text:latest

# Open WebUI integration: route through Open WebUI API for RAG, knowledge bases, web search
# Triggered by prefixing input with > e.g. "> what does my Nextcloud calendar say?"
# Set this to your Open WebUI instance URL
OPENWEBUI_URL=http://192.168.12.30:8088
OPENWEBUI_MODEL=codestral:22b

# Claude API (Anthropic) — gives full Claude capability when set
# When ANTHROPIC_API_KEY is set, ALL agent requests use Claude instead of local Ollama
# This is the same model that powers Oz/Warp — full reasoning, tool use, long context
# Get key: https://console.anthropic.com
# Unset or remove to fall back to local Ollama (privacy mode)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-5  (or claude-opus-4-5 for maximum capability)

# SearXNG (CT-300 once installed)
# SEARXNG_URL=http://192.168.12.30:8082

# Fast model for classification, prediction
OLLAMA_FAST_MODEL=llama3.2:3b

# Vision model (for screen context)
VISION_MODEL=llama3.2-vision:11b

# Embedding model for RAG
EMBEDDING_MODEL=nomic-embed-text:latest

AI_TIMEOUT=120
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=8192
OLLAMA_KEEP_ALIVE=24h

# ── Vision ────────────────────────────────────────────────────────────────────
OCR_ENGINE=tesseract
VISION_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=nexus_terminal=info
LOG_LEVEL=INFO
