#!/usr/bin/env bash
CFG="$HOME/.config/game-router/games.tsv"
name="$1"; shift
cmd="$*"
if [[ -z "$name" || -z "$cmd" ]]; then
  echo "Usage: game-add-native <name> <command...>"
  exit 1
fi
mkdir -p "$(dirname "$CFG")"
touch "$CFG"
grep -v -F "${name}	" "$CFG" > "${CFG}.tmp" || true
printf "%s\tnative\t%s\n" "$name" "$cmd" >> "${CFG}.tmp"
mv "${CFG}.tmp" "$CFG"
echo "Added native game: $name"
