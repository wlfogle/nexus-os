#!/usr/bin/env bash
# Battlezone Combat Commander Direct Launcher for PortProton
export PW_AUTOINSTALL_EXE="/media/lou/Games/Games/Battlezone Combat Commander/bzcc.exe"
export PW_PREFIX_NAME="BATTLEZONE_CC"
export PW_VULKAN_USE="1"
